---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allWorks = await getCollection('works');
---

<Layout>
  <header class="py-12">
    <h1 class="text-4xl font-extrabold mb-4">Game Engineer Portfolio</h1>
    <p class="text-slate-400 text-lg max-w-2xl">
      VRコンテンツ開発とネットワーク遅延の研究に取り組んでいます。
      主にUnity / C#を用いたインタラクティブな体験の構築が得意です。
    </p>
  </header>

  <section>
    <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
      <span class="w-8 h-1 bg-blue-500 rounded-full"></span>
      Featured Works
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {allWorks.map(work => (
        <a href={`${import.meta.env.BASE_URL}/works/${work.slug}`} class="group">
          <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden hover:border-blue-500 transition-all hover:-translate-y-1 shadow-lg">
            {/* 画像があれば表示、なければプレースホルダー */}
            <div class="aspect-video bg-slate-700 relative overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-slate-500 italic">
                {work.data.title}
              </div>
            </div>
            
            <div class="p-5">
              <div class="flex gap-2 mb-3">
                {work.data.tags.map(tag => (
                  <span class="text-[10px] uppercase tracking-wider bg-slate-900 text-blue-400 px-2 py-0.5 rounded border border-blue-900/50">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-xl font-bold mb-2 group-hover:text-blue-400 transition-colors">
                {work.data.title}
              </h3>
              <p class="text-slate-400 text-sm line-clamp-2">
                {work.data.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>