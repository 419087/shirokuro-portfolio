---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import TagFilterButton from "../../components/TagFilterButton.astro";
import TagWorksPopup from "../../components/TagWorksPopup.astro";

export async function getStaticPaths() {
  const workEntries = await getCollection("works");
  return workEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const getYouTubeEmbedUrl = (url: string) => {
  const normalizedUrl = new URL(url);
  const pathname = normalizedUrl.pathname;

  if (normalizedUrl.hostname.includes("youtube.com")) {
    if (pathname.startsWith("/embed/")) {
      return url;
    }

    if (pathname.startsWith("/shorts/")) {
      const videoId = pathname.split("/")[2];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
    }

    const videoId = normalizedUrl.searchParams.get("v");
    return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
  }

  if (normalizedUrl.hostname.includes("youtu.be")) {
    const videoId = pathname.split("/").filter(Boolean)[0];
    return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
  }

  return null;
};

const youtubeEmbedUrl = entry.data.youtubeUrl
  ? getYouTubeEmbedUrl(entry.data.youtubeUrl)
  : null;
---

<Layout>
  <article class="mx-auto w-full max-w-3xl">
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="inline-flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-blue-400"
    >
      <span aria-hidden="true">←</span>
      <span>トップへ戻る</span>
    </a>

    <section class="mt-6 border-t border-slate-700/80 pt-6 md:pt-8">
      <header class="border-b border-slate-700/80 pb-6 md:pb-8">
        <p
          class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300/90"
        >
          Work Detail
        </p>
        <h1
          class="mt-3 text-2xl font-extrabold leading-tight text-slate-50 md:text-4xl"
        >
          {entry.data.title}
        </h1>
        <p class="mt-4 text-sm text-slate-400">
          公開日: <time datetime={entry.data.publishDate.toISOString()}>{entry.data.publishDate.toLocaleDateString("ja-JP")}</time>
        </p>

        {
          entry.data.tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap items-center gap-2">
              {entry.data.tags.map((tag) => (
                <li>
                  <TagFilterButton tag={tag} />
                </li>
              ))}
            </ul>
          )
        }

        <p class="mt-5 text-sm leading-relaxed text-slate-300 md:text-base">
          {entry.data.description}
        </p>
      </header>

      {youtubeEmbedUrl && (
        <div class="mt-6 overflow-hidden rounded-xl border border-slate-700/70 bg-black shadow-2xl shadow-cyan-950/20">
          <div class="aspect-video">
            <iframe
              class="h-full w-full"
              src={youtubeEmbedUrl}
              title={entry.data.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            />
          </div>
        </div>
      )}

      {entry.data.image && (
        <div class="mt-6 overflow-hidden rounded-lg">
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            class="w-full object-cover"
          />
        </div>
      )}

      <div
        class="pt-6 md:pt-8 [&_a]:text-blue-400 [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-blue-400/70 [&_a:hover]:text-blue-300 [&_a:hover]:decoration-blue-300 [&_h2]:mt-8 [&_h2]:border-l-4 [&_h2]:border-cyan-400/80 [&_h2]:pl-3 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-100 [&_p]:mt-4 [&_p]:leading-8 [&_p]:text-slate-200 [&>ul]:mt-4 [&>ul]:list-disc [&>ul]:space-y-2 [&>ul]:pl-5 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-5 [&_li>p]:mt-0 [&_li>p]:mb-0 [&_li>ul]:mt-2 [&_li>ol]:mt-2 [&_li]:text-slate-200"
      >
        <Content />
      </div>

      <TagWorksPopup />
    </section>
  </article>
</Layout>
