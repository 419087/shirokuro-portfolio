---
// src/layouts/Layout.astro
import '../styles/global.css';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href=`${import.meta.env.BASE_URL}/favicon.svg` />
    <title>Kazuki Portfolio</title>
  </head>
  <body class="bg-slate-900 text-slate-100 antialiased min-h-screen">
    <nav class="border-b border-slate-800 p-4 sticky top-0 bg-slate-900/80 backdrop-blur-md z-50">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <a href="/" class="text-xl font-bold bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
          shirokuro.Portfolio
        </a>
        <div class="space-x-6 text-sm font-medium">
          <a href="/" class="hover:text-blue-400 transition-colors">Home</a>
          <a href="/works" class="hover:text-blue-400 transition-colors">Works</a>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto p-6">
      <slot />
    </main>

    <footer class="text-center p-10 text-slate-500 text-sm">
      &copy; 2026 Kazuki - Built with Astro & Tailwind CSS
    </footer>
  </body>
</html>