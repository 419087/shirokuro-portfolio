---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<button
  type="button"
  data-tag-button
  data-tag={tag}
  class="inline-flex items-center rounded-md border border-blue-300/50 bg-slate-900/90 px-2 py-0.5 text-[12px] tracking-[0.06em] text-blue-300 transition-colors hover:border-blue-300 hover:text-blue-200"
>
  {tag}
</button>
